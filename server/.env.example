PORT=3001
DATABASE_URL=postgres://cinema:cinema@localhost:5432/cinema
DB_RUN_MIGRATIONS=true
JWT_SECRET=change-me
JWT_EXPIRES_IN_SECONDS=604800
CORS_ORIGINS=http://localhost:4200
CORS_CREDENTIALS=true
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=30

# Optional Web Push (VAPID URL-safe base64 from `npx web-push generate-vapid-keys`).
# Public key is served at GET /api/push/vapid-public for the browser Push API.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

