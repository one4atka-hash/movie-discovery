PORT=3001
DATABASE_URL=postgres://cinema:cinema@localhost:5432/cinema
DB_RUN_MIGRATIONS=true
JWT_SECRET=change-me
JWT_EXPIRES_IN_SECONDS=604800
CORS_ORIGINS=http://localhost:4200
CORS_CREDENTIALS=true
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=30

# Optional Web Push (VAPID URL-safe base64 from `npx web-push generate-vapid-keys`).
# Public key is served at GET /api/push/vapid-public for the browser Push API.
# Subject is required for outbound sends (mailto: or https: URL).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Dev-only: POST /api/push/dev/send-self (JWT) — send test Web Push to stored subscriptions.
DEV_PUSH_SEND_ENABLED=false

# Dev-only: POST /api/email/dev/send-test (JWT) — send plain-text test to account email (requires SMTP_*).
DEV_EMAIL_SEND_ENABLED=false
# Outbound SMTP (optional; required for dev send-test and future email delivery).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

